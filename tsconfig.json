{
  "extends": "@tsconfig/react-native/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "jsx": "react-native",
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "skipLibCheck": true,
    "types": ["react", "react-native"],
    "baseUrl": ".",
    "paths": {
      "*": ["./src/*"]
    }
  },
  "include": ["src/**/*", "index.js", "babel.config.js", "metro.config.js"],
  "exclude": ["node_modules", "android", "ios"]
}
