source 'https://rubygems.org'

# You may use http://rbenv.org/ or https://rvm.io/ to install and use this version
ruby ">= 2.6.10"

# Podfile.lock was generated with CocoaPods 1.16.2.
gem 'cocoapods', '>= 1.13', '< 1.17'
gem 'activesupport', '>= 6.1.7.5', '< 7.1.0'

# ffi 1.17.3+ requires Ruby 3.0+, but macOS system Ruby is 2.6.10.
gem 'ffi', '< 1.17.3'

# Ruby 2.6 ships logger 1.3.0 as a default gem. Keep Bundler aligned with it
# so RUBYOPT=-rlogger can work around ActiveSupport's Logger load-order issue.
gem 'logger', '1.3.0'
